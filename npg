#!/usr/bin/env php
<?php

declare(strict_types=1);

// npg — convenience CLI. Nothing here is required for the app to run; the app
// runs under any PHP server pointed at public/. This script just bundles the
// common dev tasks behind one entry point.

// The CLI runs from the app root (this script lives there). It boots the
// framework the same way the web entry does, then reads layout from
// config('paths.*').
$appRoot = __DIR__;

require $appRoot . '/lib/npg/bootstrap.php';

boot($appRoot);

$command = $argv[1] ?? '';

switch ($command) {
    case 'serve':
        $docroot = escapeshellarg($appRoot . '/public');
        fwrite(STDOUT, "Serving public/ at http://localhost:8000 (Ctrl-C to stop)\n");
        passthru('php -S localhost:8000 -t ' . $docroot, $code);
        exit($code);

    case 'migrate':
        $applied = run_migrations(config('paths.migrations'));
        if ($applied === []) {
            fwrite(STDOUT, "Nothing to migrate.\n");
            exit(0);
        }
        foreach ($applied as $name) {
            fwrite(STDOUT, "Applied {$name}\n");
        }
        exit(0);

    case 'test':
        // Shell out to the framework runner (lib/npg/run_tests.php) — a fresh
        // process that boots itself against .env.testing. Any extra args are
        // passed through as specific test files.
        $cmd = 'php ' . escapeshellarg($appRoot . '/lib/npg/run_tests.php');
        foreach (array_slice($argv, 2) as $file) {
            $cmd .= ' ' . escapeshellarg($file);
        }
        passthru($cmd, $code);
        exit($code);

    case 'make:route':
        $json = false;
        $positional = [];
        foreach (array_slice($argv, 2) as $arg) {
            if ($arg === '--json') {
                $json = true;
                continue;
            }
            $positional[] = $arg;
        }

        $pattern = $positional[0] ?? '';
        $handler = $positional[1] ?? '';
        if ($pattern === '' || $handler === '') {
            fwrite(STDERR, "Usage: ./npg make:route <pattern> <handler> [--json]\n");
            exit(2);
        }

        try {
            $changes = make_route(
                $pattern,
                $handler,
                config('paths.handlers'),
                config('paths.views'),
                config('paths.routes'),
                $json,
            );
        } catch (Throwable $e) {
            fwrite(STDERR, "Could not make route: {$e->getMessage()}\n");
            exit(1);
        }

        foreach ($changes as $change) {
            fwrite(STDOUT, "{$change}\n");
        }
        exit(0);

    case 'new':
        $target = $argv[2] ?? '';
        if ($target === '') {
            fwrite(STDERR, "Usage: ./npg new <dir>\n");
            exit(2);
        }

        $targetRoot = cli_absolute_path($target);
        try {
            $created = scaffold_app($appRoot, $targetRoot);
        } catch (Throwable $e) {
            fwrite(STDERR, "Could not scaffold app: {$e->getMessage()}\n");
            exit(1);
        }

        fwrite(STDOUT, "Created npg app at {$targetRoot}\n");
        foreach ($created as $entry) {
            fwrite(STDOUT, "  {$entry}\n");
        }
        fwrite(STDOUT, "\nNext:\n");
        fwrite(STDOUT, "  cd {$targetRoot}\n");
        fwrite(STDOUT, "  cp .env.example .env                 # then set your DB credentials\n");
        fwrite(STDOUT, "  ./npg migrate\n");
        fwrite(STDOUT, "  ./npg serve\n");
        fwrite(STDOUT, "  cp .env.testing.example .env.testing # for tests, then: ./npg test\n");
        exit(0);

    case 'update':
        $target = $argv[2] ?? '';
        if ($target === '') {
            fwrite(STDERR, "Usage: ./npg update <dir>\n");
            exit(2);
        }

        $targetRoot = cli_absolute_path($target);
        try {
            update_framework($appRoot, $targetRoot);
        } catch (Throwable $e) {
            fwrite(STDERR, "Could not update framework: {$e->getMessage()}\n");
            exit(1);
        }

        fwrite(STDOUT, "Updated lib/ in {$targetRoot} from {$appRoot}\n");
        exit(0);

    default:
        fwrite(STDERR, "Usage: ./npg <command>\n\n");
        fwrite(STDERR, "Commands:\n");
        fwrite(STDERR, "  serve            Start a dev server (php -S) with public/ as docroot\n");
        fwrite(STDERR, "  migrate          Apply pending migrations in migrations/\n");
        fwrite(STDERR, "  test [files...]  Run the test suite (lib/npg/run_tests.php), optionally specific files\n");
        fwrite(STDERR, "  make:route <pattern> <handler> [--json]  Scaffold a handler + routes.php entry (and a view unless --json)\n");
        fwrite(STDERR, "  new <dir>        Scaffold a new app and vendor lib/npg/ + npg into it\n");
        fwrite(STDERR, "  update <dir>     Re-copy this install's lib/npg/ into an existing app\n");
        exit($command === '' ? 0 : 2);
}

/**
 * Resolve a user-supplied path to an absolute one, relative to the current
 * working directory (not the app root), so `./npg new myapp` lands where the
 * user is standing.
 */
function cli_absolute_path(string $path): string
{
    if ($path === '' || $path[0] === '/') {
        return $path;
    }

    return rtrim((string) getcwd(), '/') . '/' . $path;
}
